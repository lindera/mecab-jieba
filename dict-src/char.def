#
# Chinese character category map for lindera CRF training
#

###################################################################################
#
#  CHARACTER CATEGORY DEFINITION
#
#  CATEGORY_NAME INVOKE GROUP LENGTH
#
#   - CATEGORY_NAME: Name of category. DEFAULT is mandatory.
#   - INVOKE: 1/0: always invoke unknown word processing, even when the word is in the lexicon
#   - GROUP:  1/0: make a new word by grouping the same character category
#   - LENGTH: n:   1 to n length new words are added
#
DEFAULT         0 1 0
SPACE           0 1 0
CHINESE         0 0 2
SYMBOL          1 1 0
NUMERIC         1 1 0
ALPHA           1 1 0
HIRAGANA        0 1 2
KATAKANA        1 1 2
CHINESENUMERIC  0 1 0
GREEK           1 1 0
CYRILLIC        1 1 0

###################################################################################
#
# CODE(UCS2) TO CATEGORY MAPPING
#

# SPACE
0x0020 SPACE
0x00D0 SPACE
0x0009 SPACE
0x000B SPACE
0x000A SPACE

# ASCII
0x0021..0x002F SYMBOL
0x0030..0x0039 NUMERIC
0x003A..0x0040 SYMBOL
0x0041..0x005A ALPHA
0x005B..0x0060 SYMBOL
0x0061..0x007A ALPHA
0x007B..0x007E SYMBOL

# Latin
0x00A1..0x00BF SYMBOL
0x00C0..0x00FF ALPHA
0x0100..0x017F ALPHA
0x0180..0x0236 ALPHA
0x1E00..0x1EF9 ALPHA

# CYRILLIC
0x0400..0x04F9 CYRILLIC
0x0500..0x050F CYRILLIC

# GREEK
0x0374..0x03FB GREEK

# HIRAGANA
0x3041..0x309F HIRAGANA

# KATAKANA
0x30A1..0x30FF KATAKANA
0x31F0..0x31FF KATAKANA
0x30FC KATAKANA

# Half-width KATAKANA
0xFF66..0xFF9D KATAKANA
0xFF9E..0xFF9F KATAKANA

# CHINESE (CJK Unified Ideographs and extensions)
0x2E80..0x2EF3 CHINESE
0x2F00..0x2FD5 CHINESE
0x3005 CHINESE
0x3007 CHINESE
0x3400..0x4DB5 CHINESE
0x4E00..0x9FA5 CHINESE
0xF900..0xFA2D CHINESE
0xFA30..0xFA6A CHINESE

# CHINESE-NUMERIC (一 二 三 四 五 六 七 八 九 十 百 千 萬 万 億 亿 兆)
0x4E00 CHINESENUMERIC CHINESE
0x4E8C CHINESENUMERIC CHINESE
0x4E09 CHINESENUMERIC CHINESE
0x56DB CHINESENUMERIC CHINESE
0x4E94 CHINESENUMERIC CHINESE
0x516D CHINESENUMERIC CHINESE
0x4E03 CHINESENUMERIC CHINESE
0x516B CHINESENUMERIC CHINESE
0x4E5D CHINESENUMERIC CHINESE
0x5341 CHINESENUMERIC CHINESE
0x767E CHINESENUMERIC CHINESE
0x5343 CHINESENUMERIC CHINESE
0x842C CHINESENUMERIC CHINESE
0x4E07 CHINESENUMERIC CHINESE
0x5104 CHINESENUMERIC CHINESE
0x4EBF CHINESENUMERIC CHINESE
0x5146 CHINESENUMERIC CHINESE

# ZENKAKU (full-width forms)
0xFF10..0xFF19 NUMERIC
0xFF21..0xFF3A ALPHA
0xFF41..0xFF5A ALPHA
0xFF01..0xFF0F SYMBOL
0xFF1A..0xFF20 SYMBOL
0xFF3B..0xFF40 SYMBOL
0xFF5B..0xFF65 SYMBOL
0xFFE0..0xFFEF SYMBOL

# OTHER SYMBOLS
0x2000..0x206F SYMBOL
0x2070..0x209F NUMERIC
0x20A0..0x20CF SYMBOL
0x20D0..0x20FF SYMBOL
0x2100..0x214F SYMBOL
